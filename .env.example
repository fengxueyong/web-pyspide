# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=web_collector

# MinIO（与 S3 API 兼容）
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=admin123456
MINIO_SECURE=false
MINIO_BUCKET=web-collector

# 媒体文件下载：设为 true 才会下载图片等文件到 MinIO
MEDIA_DOWNLOAD=false

# MySQL 8
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=web_collector
MYSQL_USER=root
MYSQL_PASSWORD=root123456

# 爬虫
MAX_DEPTH=2

